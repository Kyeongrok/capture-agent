<?xml version="1.0" encoding="utf-8"?>
<assembly manifestVersion="1.0" xmlns="urn:schemas-microsoft-com:asm.v1">
  <assemblyIdentity version="1.0.0.0" processorArchitecture="msil" name="CaptureAgent" type="win32" />
  <description>Screen Capture Application</description>

  <!-- DPI Awareness 설정 (고해상도 디스플레이 지원) -->
  <!--
    중요: PerMonitorV2 는 <dpiAwareness>(2016 스키마)로만 설정할 수 있다.
    <dpiAware>(2005 스키마)에 "PerMonitorV2,PerMonitor" 를 넣으면 Windows 가
    "인식할 수 없는 문자열"로 처리해 프로세스가 DPI Unaware 가 된다. 그러면
    200% 모니터에서 화면이 1920x1080 으로 가상화되어 캡처가 절반 크기로 저장된다.
    - <dpiAwareness>: Windows 10 1607+ 용. PerMonitorV2 우선, 미지원 시 PerMonitor 로 폴백.
    - <dpiAware>:     구버전 Windows 폴백용. true/PM = Per-Monitor(8.1), System aware(7/8).
    Win10 1607+ 에서는 <dpiAwareness> 가 존재하면 <dpiAware> 는 무시된다.
  -->
  <asmv3:application xmlns:asmv3="urn:schemas-microsoft-com:asm.v3">
    <asmv3:windowsSettings>
      <dpiAware xmlns="http://schemas.microsoft.com/SMI/2005/WindowsSettings">true/PM</dpiAware>
      <dpiAwareness xmlns="http://schemas.microsoft.com/SMI/2016/WindowsSettings">PerMonitorV2,PerMonitor</dpiAwareness>
    </asmv3:windowsSettings>
  </asmv3:application>

  <!-- Windows 호환성 -->
  <compatibility xmlns="urn:schemas-microsoft-com:compatibility.v1">
    <application>
      <supportedOS Id="{35138b9a-5d96-4fbd-8e2d-a2440225f93a}" /> <!-- Windows 7 -->
      <supportedOS Id="{4a2f28e3-53b9-4441-ba9c-d69d4a4a6e38}" /> <!-- Windows 8 -->
      <supportedOS Id="{1f676c76-80e1-6b23-1b78-7f766f014de6}" /> <!-- Windows 8.1 -->
      <supportedOS Id="{8e0f7a12-bfb3-4fe8-b9a5-48fd50a15a9a}" /> <!-- Windows 10/11 -->
    </application>
  </compatibility>

  <!-- UAC 권한 -->
  <trustInfo xmlns="urn:schemas-microsoft-com:security">
    <security>
      <requestedPrivileges>
        <requestedExecutionLevel level="asInvoker" uiAccess="false" />
      </requestedPrivileges>
    </security>
  </trustInfo>
</assembly>
