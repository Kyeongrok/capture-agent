<Window
    x:Class="CaptureAgent.Forms.UI.Views.MacroConfigWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="매크로 설정"
    Width="340"
    Height="330"
    Background="#2D2D30"
    ResizeMode="NoResize"
    Topmost="True"
    WindowStartupLocation="Manual"
    WindowStyle="ToolWindow">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  마우스 포인터 위치  -->
        <TextBlock
            Grid.Row="0"
            Margin="0,0,0,6"
            FontSize="13"
            FontWeight="Bold"
            Foreground="#E0E0E0"
            Text="마우스 포인터 위치" />

        <StackPanel
            Grid.Row="1"
            Margin="0,0,0,8"
            Orientation="Horizontal">
            <TextBlock
                VerticalAlignment="Center"
                Foreground="#B0B0B0"
                Text="X:" />
            <TextBox
                x:Name="PositionXBox"
                Width="60"
                Margin="6,0,12,0"
                Padding="4,2"
                Text="0" />
            <TextBlock
                VerticalAlignment="Center"
                Foreground="#B0B0B0"
                Text="Y:" />
            <TextBox
                x:Name="PositionYBox"
                Width="60"
                Margin="6,0,12,0"
                Padding="4,2"
                Text="0" />
        </StackPanel>

        <Button
            x:Name="PickPositionButton"
            Grid.Row="2"
            Height="30"
            Margin="0,0,0,16"
            Background="#3E3E42"
            BorderBrush="#4CAF50"
            BorderThickness="1"
            Content="현재 마우스 위치 지정 (3초 후 캡처)"
            Foreground="#E0E0E0" />

        <!--  딜레이  -->
        <StackPanel
            Grid.Row="3"
            Margin="0,0,0,8"
            Orientation="Horizontal">
            <TextBlock
                VerticalAlignment="Center"
                FontSize="13"
                FontWeight="Bold"
                Foreground="#E0E0E0"
                Text="딜레이:" />
            <TextBox
                x:Name="DelayBox"
                Width="70"
                Margin="10,0,6,0"
                Padding="4,2"
                Text="1.0" />
            <TextBlock
                VerticalAlignment="Center"
                Foreground="#B0B0B0"
                Text="초" />
        </StackPanel>

        <!--  반복 횟수  -->
        <StackPanel
            Grid.Row="4"
            Margin="0,0,0,8"
            Orientation="Horizontal">
            <TextBlock
                VerticalAlignment="Center"
                FontSize="13"
                FontWeight="Bold"
                Foreground="#E0E0E0"
                Text="반복 횟수:" />
            <TextBox
                x:Name="RepeatBox"
                Width="70"
                Margin="10,0,6,0"
                Padding="4,2"
                Text="1" />
            <TextBlock
                VerticalAlignment="Center"
                Foreground="#B0B0B0"
                Text="회" />
        </StackPanel>

        <TextBlock
            x:Name="StatusText"
            Grid.Row="5"
            VerticalAlignment="Center"
            FontSize="12"
            Foreground="#4CAF50"
            Text="" />

        <StackPanel
            Grid.Row="6"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <Button
                x:Name="ConfirmButton"
                Width="80"
                Height="32"
                Margin="0,0,8,0"
                Background="#4CAF50"
                BorderThickness="0"
                Content="실행"
                Foreground="White" />
            <Button
                x:Name="CancelButton"
                Width="80"
                Height="32"
                Background="#3E3E42"
                BorderThickness="0"
                Content="취소"
                Foreground="#E0E0E0" />
        </StackPanel>
    </Grid>
</Window>
