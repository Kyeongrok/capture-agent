<Window
    x:Class="CaptureAgent.Forms.UI.Views.ScreenOverlayWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    AllowsTransparency="True"
    Background="Transparent"
    Topmost="True"
    WindowState="Maximized"
    WindowStyle="None">
    <Grid>
        <Border Background="#4D000000" />
        <Canvas x:Name="SelectionCanvas" Background="Transparent">
            <TextBlock
                x:Name="DimensionText"
                Padding="6,4"
                Background="#80000000"
                FontSize="14"
                FontWeight="Bold"
                Foreground="White"
                Text="0x0"
                Visibility="Hidden" />
        </Canvas>
    </Grid>
</Window>
