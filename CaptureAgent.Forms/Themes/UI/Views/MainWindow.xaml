<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:support="clr-namespace:CaptureAgent.Support.UI.Units;assembly=CaptureAgent.Support"
    xmlns:views="clr-namespace:CaptureAgent.Forms.UI.Views">
    <Style BasedOn="{StaticResource {x:Type support:CaptureAgentWindow}}" TargetType="{x:Type views:MainWindow}">
        <Setter Property="Title" Value="캡춰 앱" />
        <Setter Property="Width" Value="1400" />
        <Setter Property="Height" Value="800" />
        <Setter Property="MinWidth" Value="900" />
        <Setter Property="MinHeight" Value="600" />
        <Setter Property="WindowStyle" Value="None" />
        <Setter Property="Content">
            <Setter.Value>
                <Grid Background="#1A1A1D">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="46" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!--  타이틀바  -->
                    <Border
                        Grid.Row="0"
                        Background="#212126"
                        BorderBrush="#0DFFFFFF"
                        BorderThickness="0,0,0,1">
                        <Grid Margin="16,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel
                                Grid.Column="0"
                                VerticalAlignment="Center"
                                Orientation="Horizontal">
                                <Border
                                    Width="18"
                                    Height="18"
                                    Margin="0,0,10,0"
                                    Background="#F2A33C">
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="10"
                                        Text="📷" />
                                </Border>
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="13"
                                    FontWeight="600"
                                    Foreground="#E6E6EA"
                                    Text="캡춰 앱"
                                    TextWrapping="NoWrap" />
                            </StackPanel>

                            <StackPanel
                                Grid.Column="2"
                                Height="46"
                                Orientation="Horizontal">
                                <Button
                                    Width="46"
                                    VerticalAlignment="Stretch"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Foreground="#9A9AA0">
                                    <TextBlock FontSize="14" Text="−" />
                                </Button>
                                <Button
                                    Width="46"
                                    VerticalAlignment="Stretch"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Foreground="#9A9AA0">
                                    <TextBlock FontSize="12" Text="□" />
                                </Button>
                                <Button
                                    Width="46"
                                    VerticalAlignment="Stretch"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Foreground="#9A9AA0">
                                    <TextBlock FontSize="14" Text="✕" />
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!--  메인 콘텐츠  -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="78" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="288" />
                        </Grid.ColumnDefinitions>

                        <!--  네비게이션 레일  -->
                        <Border
                            Grid.Column="0"
                            Background="#161619"
                            BorderBrush="#0DFFFFFF"
                            BorderThickness="0,0,1,0">
                            <StackPanel Margin="0,12,0,0" VerticalAlignment="Top">
                                <Button
                                    Width="78"
                                    Height="56"
                                    Padding="0"
                                    Background="Transparent"
                                    BorderThickness="0">
                                    <Grid>
                                        <Border
                                            Width="3"
                                            Height="24"
                                            HorizontalAlignment="Left"
                                            Background="#F2A33C" />
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock
                                                HorizontalAlignment="Center"
                                                FontSize="18"
                                                Text="📸" />
                                            <TextBlock
                                                Margin="0,2,0,0"
                                                HorizontalAlignment="Center"
                                                FontSize="10"
                                                FontWeight="600"
                                                Foreground="#F2A33C"
                                                Text="캡춰" />
                                        </StackPanel>
                                    </Grid>
                                </Button>
                                <Button
                                    Width="78"
                                    Height="56"
                                    Padding="0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Foreground="#71717A">
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock
                                            HorizontalAlignment="Center"
                                            FontSize="18"
                                            Text="🎯" />
                                        <TextBlock
                                            Margin="0,2,0,0"
                                            HorizontalAlignment="Center"
                                            FontSize="10"
                                            FontWeight="500"
                                            Text="매크로" />
                                    </StackPanel>
                                </Button>
                                <Button
                                    Width="78"
                                    Height="56"
                                    Padding="0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Foreground="#71717A">
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock
                                            HorizontalAlignment="Center"
                                            FontSize="18"
                                            Text="⏱️" />
                                        <TextBlock
                                            Margin="0,2,0,0"
                                            HorizontalAlignment="Center"
                                            FontSize="10"
                                            FontWeight="500"
                                            Text="기록" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>

                        <!--  중앙 캔버스  -->
                        <Grid
                            Grid.Column="1"
                            Margin="20"
                            Background="#1A1A1D">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock
                                        FontSize="16"
                                        FontWeight="700"
                                        Foreground="#F3F3F5"
                                        Text="영역 캡춰" />
                                    <TextBlock
                                        Margin="0,2,0,0"
                                        FontSize="12"
                                        Foreground="#7C7C82"
                                        Text="화면에서 사각형 영역을 지정하고 좌표를 세부 조정하세요" />
                                </StackPanel>
                                <Button
                                    Grid.Column="1"
                                    Width="Auto"
                                    Height="36"
                                    Padding="15,0"
                                    Background="Transparent"
                                    BorderBrush="#24FFFFFF"
                                    BorderThickness="1"
                                    Command="{Binding SelectNewRegionCommand}"
                                    Foreground="#D8D8DC">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock
                                            Margin="0,0,7,0"
                                            FontSize="12"
                                            Text="📸" />
                                        <TextBlock
                                            FontSize="13"
                                            FontWeight="500"
                                            Text="새 영역 선택" />
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Grid>

                        <!--  우측 인스펙터  -->
                        <Border
                            Grid.Column="2"
                            Background="#161619"
                            BorderBrush="#0DFFFFFF"
                            BorderThickness="1,0,0,0">
                            <ScrollViewer Margin="20,22,20,0">
                                <StackPanel>
                                    <StackPanel Margin="0,0,0,16" Orientation="Horizontal">
                                        <Ellipse
                                            Width="5"
                                            Height="5"
                                            VerticalAlignment="Center"
                                            Fill="#F2A33C" />
                                        <TextBlock
                                            Margin="7,0,0,0"
                                            FontSize="11"
                                            FontWeight="700"
                                            Foreground="#8A8A90"
                                            Text="영역 좌표" />
                                    </StackPanel>

                                    <TextBlock
                                        Margin="0,0,0,8"
                                        FontSize="11"
                                        FontWeight="500"
                                        Foreground="#7A7A80"
                                        Text="시작점" />
                                    <Grid Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border
                                            Grid.Column="0"
                                            Height="38"
                                            Margin="0,0,5,0"
                                            Background="#202024"
                                            BorderBrush="#F2A33C"
                                            BorderThickness="1">
                                            <Grid Margin="12,0,5,0">
                                                <TextBlock
                                                    VerticalAlignment="Center"
                                                    FontSize="10"
                                                    Foreground="#6A6A70"
                                                    Text="X" />
                                                <TextBlock
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Center"
                                                    FontFamily="Consolas"
                                                    FontSize="14"
                                                    Foreground="#F0F0F2"
                                                    Text="100" />
                                            </Grid>
                                        </Border>
                                        <Border
                                            Grid.Column="1"
                                            Height="38"
                                            Background="#202024"
                                            BorderBrush="#14FFFFFF"
                                            BorderThickness="1">
                                            <Grid Margin="12,0,5,0">
                                                <TextBlock
                                                    VerticalAlignment="Center"
                                                    FontSize="10"
                                                    Foreground="#6A6A70"
                                                    Text="Y" />
                                                <TextBlock
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Center"
                                                    FontFamily="Consolas"
                                                    FontSize="14"
                                                    Foreground="#F0F0F2"
                                                    Text="100" />
                                            </Grid>
                                        </Border>
                                    </Grid>

                                    <TextBlock
                                        Margin="0,0,0,8"
                                        FontSize="11"
                                        FontWeight="500"
                                        Foreground="#7A7A80"
                                        Text="끝점" />
                                    <Grid Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border
                                            Grid.Column="0"
                                            Height="38"
                                            Margin="0,0,5,0"
                                            Background="#202024"
                                            BorderBrush="#14FFFFFF"
                                            BorderThickness="1">
                                            <Grid Margin="12,0,5,0">
                                                <TextBlock
                                                    VerticalAlignment="Center"
                                                    FontSize="10"
                                                    Foreground="#6A6A70"
                                                    Text="X" />
                                                <TextBlock
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Center"
                                                    FontFamily="Consolas"
                                                    FontSize="14"
                                                    Foreground="#F0F0F2"
                                                    Text="200" />
                                            </Grid>
                                        </Border>
                                        <Border
                                            Grid.Column="1"
                                            Height="38"
                                            Background="#202024"
                                            BorderBrush="#14FFFFFF"
                                            BorderThickness="1">
                                            <Grid Margin="12,0,5,0">
                                                <TextBlock
                                                    VerticalAlignment="Center"
                                                    FontSize="10"
                                                    Foreground="#6A6A70"
                                                    Text="Y" />
                                                <TextBlock
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Center"
                                                    FontFamily="Consolas"
                                                    FontSize="14"
                                                    Foreground="#F0F0F2"
                                                    Text="200" />
                                            </Grid>
                                        </Border>
                                    </Grid>

                                    <TextBlock
                                        Margin="0,0,0,8"
                                        FontSize="11"
                                        FontWeight="500"
                                        Foreground="#7A7A80"
                                        Text="크기" />
                                    <Grid Margin="0,0,0,20">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border
                                            Grid.Column="0"
                                            Height="38"
                                            Margin="0,0,5,0"
                                            Background="#202024"
                                            BorderBrush="#14FFFFFF"
                                            BorderThickness="1">
                                            <Grid Margin="12,0,5,0">
                                                <TextBlock
                                                    VerticalAlignment="Center"
                                                    FontSize="10"
                                                    Foreground="#6A6A70"
                                                    Text="W" />
                                                <TextBlock
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Center"
                                                    FontFamily="Consolas"
                                                    FontSize="14"
                                                    Foreground="#F0F0F2"
                                                    Text="100" />
                                            </Grid>
                                        </Border>
                                        <Border
                                            Grid.Column="1"
                                            Height="38"
                                            Background="#202024"
                                            BorderBrush="#14FFFFFF"
                                            BorderThickness="1">
                                            <Grid Margin="12,0,5,0">
                                                <TextBlock
                                                    VerticalAlignment="Center"
                                                    FontSize="10"
                                                    Foreground="#6A6A70"
                                                    Text="H" />
                                                <TextBlock
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Center"
                                                    FontFamily="Consolas"
                                                    FontSize="14"
                                                    Foreground="#F0F0F2"
                                                    Text="100" />
                                            </Grid>
                                        </Border>
                                    </Grid>

                                    <Border
                                        Height="1"
                                        Margin="0,0,0,18"
                                        Background="#0FFFFFFF" />

                                    <TextBlock
                                        Margin="0,0,0,9"
                                        FontSize="11"
                                        FontWeight="500"
                                        Foreground="#7A7A80"
                                        Text="저장 형식" />
                                    <Border
                                        Height="32"
                                        Margin="0,0,0,18"
                                        Background="#202024"
                                        BorderBrush="#12FFFFFF"
                                        BorderThickness="1">
                                        <Grid Margin="3">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Button
                                                Grid.Column="0"
                                                Background="#F2A33C"
                                                BorderThickness="0"
                                                Content="PNG"
                                                FontSize="12"
                                                FontWeight="700"
                                                Foreground="#1B1206" />
                                            <Button
                                                Grid.Column="1"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Content="JPG"
                                                FontSize="12"
                                                FontWeight="500"
                                                Foreground="#9A9AA0" />
                                            <Button
                                                Grid.Column="2"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Content="BMP"
                                                FontSize="12"
                                                FontWeight="500"
                                                Foreground="#9A9AA0" />
                                        </Grid>
                                    </Border>

                                    <Border
                                        Margin="0,0,0,12"
                                        Background="#202024"
                                        BorderBrush="#12FFFFFF"
                                        BorderThickness="1">
                                        <StackPanel Margin="12">
                                            <TextBlock
                                                Margin="0,0,0,6"
                                                FontSize="10"
                                                FontWeight="600"
                                                Foreground="#8A8A90"
                                                Text="마우스 좌표" />
                                            <TextBlock
                                                FontFamily="Consolas"
                                                FontSize="13"
                                                FontWeight="600"
                                                Foreground="#F2A33C"
                                                Text="X: 1234 · Y: 5678" />
                                        </StackPanel>
                                    </Border>

                                    <Border
                                        Margin="0,0,0,18"
                                        Background="#202024"
                                        BorderBrush="#12FFFFFF"
                                        BorderThickness="1">
                                        <StackPanel Margin="12">
                                            <TextBlock
                                                Margin="0,0,0,8"
                                                FontSize="10"
                                                FontWeight="600"
                                                Foreground="#8A8A90"
                                                Text="컬러 피커" />
                                            <Border
                                                Width="40"
                                                Height="40"
                                                Margin="0,0,0,8"
                                                Background="#F2A33C" />
                                            <TextBlock
                                                Margin="0,0,0,4"
                                                FontFamily="Consolas"
                                                FontSize="11"
                                                Foreground="#D8D8DC"
                                                Text="HEX: #F2A33C" />
                                            <TextBlock
                                                FontFamily="Consolas"
                                                FontSize="11"
                                                Foreground="#D8D8DC"
                                                Text="RGB(242, 163, 60)" />
                                        </StackPanel>
                                    </Border>

                                    <Button
                                        Height="46"
                                        HorizontalAlignment="Stretch"
                                        Background="#F2A33C"
                                        BorderThickness="0"
                                        FontSize="14"
                                        FontWeight="700"
                                        Foreground="#1B1206">
                                        <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                            <TextBlock
                                                Margin="0,0,9,0"
                                                FontSize="14"
                                                Text="📸" />
                                            <TextBlock Text="캡춰" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Grid>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
