<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:support="clr-namespace:CaptureAgent.Support.UI.Units;assembly=CaptureAgent.Support"
    xmlns:views="clr-namespace:CaptureAgent.Forms.UI.Views">

    <!--  좌표 입력칸 공통 스타일 (다크 테마에 맞춘 투명 TextBox)  -->
    <Style x:Key="CoordBoxStyle" TargetType="TextBox">
        <Setter Property="HorizontalContentAlignment" Value="Right" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="FontFamily" Value="Consolas" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="#F0F0F2" />
        <Setter Property="CaretBrush" Value="#F0F0F2" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0,0,6,0" />
    </Style>

    <Style BasedOn="{StaticResource {x:Type support:CaptureAgentWindow}}" TargetType="{x:Type views:MainWindow}">
        <Setter Property="Title" Value="캡춰앱" />
        <Setter Property="Width" Value="700" />
        <Setter Property="Height" Value="400" />
        <Setter Property="MinWidth" Value="700" />
        <Setter Property="MinHeight" Value="400" />
        <Setter Property="WindowStyle" Value="None" />
        <Setter Property="Content">
            <Setter.Value>
                <Grid Background="#2C2C2F">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="50" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="60" />
                        <RowDefinition Height="50" />
                    </Grid.RowDefinitions>

                    <!--  타이틀바  -->
                    <Border
                        Grid.Row="0"
                        Background="#3A3A3D"
                        BorderBrush="#4A4A4D"
                        BorderThickness="0,0,0,1">
                        <Grid Margin="12,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!--  좌측: 아이콘 + 제목 + 모드  -->
                            <StackPanel
                                Grid.Column="0"
                                VerticalAlignment="Center"
                                Orientation="Horizontal">
                                <Border
                                    Width="28"
                                    Height="28"
                                    Margin="0,0,8,0"
                                    Background="#F2A33C">
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="14"
                                        Text="📸" />
                                </Border>
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="14"
                                    FontWeight="600"
                                    Foreground="#E6E6EA"
                                    Text="캡춰앱" />
                                <TextBlock
                                    Margin="12,0,0,0"
                                    VerticalAlignment="Center"
                                    FontSize="12"
                                    Foreground="#9A9AA0"
                                    Text="사각형 영역 모드" />
                            </StackPanel>

                            <!--  우측: 도구 버튼  -->
                            <StackPanel
                                Grid.Column="2"
                                VerticalAlignment="Center"
                                Orientation="Horizontal">
                                <Button
                                    Width="32"
                                    Height="32"
                                    Margin="0,0,8,0"
                                    Padding="0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Foreground="#7A7A80"
                                    ToolTip="잠금">
                                    <TextBlock FontSize="14" Text="🔒" />
                                </Button>
                                <Button
                                    Width="32"
                                    Height="32"
                                    Margin="0,0,8,0"
                                    Padding="0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Foreground="#7A7A80"
                                    ToolTip="폴더">
                                    <TextBlock FontSize="14" Text="📁" />
                                </Button>
                                <Button
                                    Width="32"
                                    Height="32"
                                    Margin="0,0,8,0"
                                    Padding="0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Foreground="#7A7A80"
                                    ToolTip="시간">
                                    <TextBlock FontSize="14" Text="⏰" />
                                </Button>
                                <Button
                                    Width="32"
                                    Height="32"
                                    Padding="0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Foreground="#7A7A80"
                                    ToolTip="도움말">
                                    <TextBlock FontSize="14" Text="❓" />
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!--  메인 콘텐츠  -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!--  좌측: 캡처 모드 버튼들  -->
                        <StackPanel
                            Grid.Column="0"
                            Margin="20,0"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">
                            <Button
                                Width="100"
                                Height="100"
                                Margin="0,0,20,0"
                                Padding="0"
                                Background="Transparent"
                                BorderBrush="#F2A33C"
                                BorderThickness="2"
                                Command="{Binding SelectNewRegionCommand}">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        FontSize="32"
                                        Text="🎯" />
                                    <TextBlock
                                        Margin="0,4,0,0"
                                        HorizontalAlignment="Center"
                                        FontSize="11"
                                        Foreground="#D8D8DC"
                                        Text="사각형 영역" />
                                </StackPanel>
                            </Button>
                            <Button
                                Width="80"
                                Height="80"
                                Margin="0,0,20,0"
                                Padding="0"
                                Background="Transparent"
                                BorderBrush="#5A5A5D"
                                BorderThickness="1">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        FontSize="28"
                                        Text="🖥️" />
                                    <TextBlock
                                        Margin="0,2,0,0"
                                        HorizontalAlignment="Center"
                                        FontSize="10"
                                        Foreground="#9A9AA0"
                                        Text="전체 화면" />
                                </StackPanel>
                            </Button>
                            <Button
                                Width="80"
                                Height="80"
                                Padding="0"
                                Background="Transparent"
                                BorderBrush="#5A5A5D"
                                BorderThickness="1">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        FontSize="28"
                                        Text="🪟" />
                                    <TextBlock
                                        Margin="0,2,0,0"
                                        HorizontalAlignment="Center"
                                        FontSize="10"
                                        Foreground="#9A9AA0"
                                        Text="특정 창" />
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <!--  우측: 매크로 + 캡처 버튼  -->
                        <StackPanel
                            Grid.Column="1"
                            Margin="0,0,30,0"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">
                            <Button
                                Width="60"
                                Height="60"
                                Margin="0,0,15,0"
                                Padding="0"
                                Background="Transparent"
                                BorderBrush="#5A5A5D"
                                BorderThickness="1">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        FontSize="20"
                                        Text="🎯" />
                                    <TextBlock
                                        Margin="0,2,0,0"
                                        HorizontalAlignment="Center"
                                        FontSize="9"
                                        Foreground="#F2A33C"
                                        Text="매크로" />
                                </StackPanel>
                            </Button>
                            <Button
                                Width="100"
                                Height="100"
                                Padding="0"
                                Background="Transparent"
                                BorderBrush="#F2A33C"
                                BorderThickness="3">
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    FontSize="36"
                                    Text="🎯" />
                            </Button>
                        </StackPanel>
                    </Grid>

                    <!--  좌표 조절 스트립  -->
                    <Border
                        Grid.Row="2"
                        Background="#3A3A3D"
                        BorderBrush="#4A4A4D"
                        BorderThickness="0,1,0,1">
                        <StackPanel
                            Margin="12"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">
                            <!--  마커  -->
                            <Ellipse
                                Width="8"
                                Height="8"
                                Margin="0,0,12,0"
                                VerticalAlignment="Center"
                                Fill="#F2A33C" />

                            <!--  좌표 시작  -->
                            <TextBlock
                                Margin="0,0,6,0"
                                VerticalAlignment="Center"
                                FontSize="11"
                                Foreground="#9A9AA0"
                                Text="시작" />
                            <Border
                                Width="60"
                                Height="32"
                                Margin="0,0,6,0"
                                Background="#202024"
                                BorderBrush="#F2A33C"
                                BorderThickness="1">
                                <TextBox Style="{StaticResource CoordBoxStyle}" Text="{Binding RegionViewModel.StartX, UpdateSourceTrigger=LostFocus}" />
                            </Border>
                            <TextBlock
                                Margin="0,0,6,0"
                                VerticalAlignment="Center"
                                FontSize="11"
                                Foreground="#9A9AA0"
                                Text="X" />

                            <Border
                                Width="60"
                                Height="32"
                                Margin="0,0,12,0"
                                Background="#202024"
                                BorderBrush="#555"
                                BorderThickness="1">
                                <TextBox Style="{StaticResource CoordBoxStyle}" Text="{Binding RegionViewModel.StartY, UpdateSourceTrigger=LostFocus}" />
                            </Border>
                            <TextBlock
                                Margin="0,0,12,0"
                                VerticalAlignment="Center"
                                FontSize="11"
                                Foreground="#9A9AA0"
                                Text="Y" />

                            <!--  구분선  -->
                            <Border
                                Width="1"
                                Height="20"
                                Margin="0,0,12,0"
                                VerticalAlignment="Center"
                                Background="#5A5A5D" />

                            <!--  좌표 끝점  -->
                            <TextBlock
                                Margin="0,0,6,0"
                                VerticalAlignment="Center"
                                FontSize="11"
                                Foreground="#9A9AA0"
                                Text="끝" />
                            <Border
                                Width="60"
                                Height="32"
                                Margin="0,0,6,0"
                                Background="#202024"
                                BorderBrush="#555"
                                BorderThickness="1">
                                <TextBox Style="{StaticResource CoordBoxStyle}" Text="{Binding RegionViewModel.EndX, UpdateSourceTrigger=LostFocus}" />
                            </Border>
                            <TextBlock
                                Margin="0,0,6,0"
                                VerticalAlignment="Center"
                                FontSize="11"
                                Foreground="#9A9AA0"
                                Text="X" />

                            <Border
                                Width="60"
                                Height="32"
                                Margin="0,0,12,0"
                                Background="#202024"
                                BorderBrush="#555"
                                BorderThickness="1">
                                <TextBox Style="{StaticResource CoordBoxStyle}" Text="{Binding RegionViewModel.EndY, UpdateSourceTrigger=LostFocus}" />
                            </Border>
                            <TextBlock
                                Margin="0,0,12,0"
                                VerticalAlignment="Center"
                                FontSize="11"
                                Foreground="#9A9AA0"
                                Text="Y" />

                            <!--  구분선  -->
                            <Border
                                Width="1"
                                Height="20"
                                Margin="0,0,12,0"
                                VerticalAlignment="Center"
                                Background="#5A5A5D" />

                            <!--  크기  -->
                            <TextBlock
                                Margin="0,0,6,0"
                                VerticalAlignment="Center"
                                FontSize="11"
                                Foreground="#9A9AA0"
                                Text="크기" />
                            <Border
                                Width="60"
                                Height="32"
                                Margin="0,0,6,0"
                                Background="#202024"
                                BorderBrush="#555"
                                BorderThickness="1">
                                <TextBox Style="{StaticResource CoordBoxStyle}" Text="{Binding RegionViewModel.Width, UpdateSourceTrigger=LostFocus}" />
                            </Border>
                            <TextBlock
                                Margin="0,0,6,0"
                                VerticalAlignment="Center"
                                FontSize="11"
                                Foreground="#9A9AA0"
                                Text="W" />

                            <Border
                                Width="60"
                                Height="32"
                                Background="#202024"
                                BorderBrush="#555"
                                BorderThickness="1">
                                <TextBox Style="{StaticResource CoordBoxStyle}" Text="{Binding RegionViewModel.Height, UpdateSourceTrigger=LostFocus}" />
                            </Border>
                            <TextBlock
                                Margin="0,0,0,0"
                                VerticalAlignment="Center"
                                FontSize="11"
                                Foreground="#9A9AA0"
                                Text="H" />
                        </StackPanel>
                    </Border>

                    <!--  하단 상태바  -->
                    <Border
                        Grid.Row="3"
                        Background="#3A3A3D"
                        BorderBrush="#4A4A4D"
                        BorderThickness="0,1,0,0">
                        <Grid Margin="12,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!--  상태 메시지  -->
                            <StackPanel
                                Grid.Column="0"
                                VerticalAlignment="Center"
                                Orientation="Horizontal">
                                <TextBlock
                                    Margin="0,0,8,0"
                                    VerticalAlignment="Center"
                                    FontSize="14"
                                    Foreground="#9A9AA0"
                                    Text="⊞" />
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="12"
                                    Foreground="#9A9AA0"
                                    Text="사각형 영역을 지정하세요." />
                            </StackPanel>

                            <!--  현재 크기  -->
                            <TextBlock
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                FontFamily="Consolas"
                                FontSize="13"
                                FontWeight="600"
                                Foreground="#F2A33C">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0} × {1}">
                                        <Binding Path="RegionViewModel.Width" />
                                        <Binding Path="RegionViewModel.Height" />
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </Grid>
                    </Border>
                </Grid>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
